<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <template id="cars_dealersheep_home_page" name="Home Page Vehículos">
    <t t-call="website.layout">
      <div class="container home-page py-5">
        <section class="home-hero mb-5">
          <div class="row align-items-center g-4">
            <div class="col-lg-7">
              <span class="vehicle-snippet-kicker">Compra y venta en Chile</span>
              <h1>Encuentra vehículos publicados con una ficha clara y filtros reales.</h1>
              <p>Explora autos, camionetas, motos y camiones con información lista para vitrina digital y contacto comercial.</p>
            </div>
            <div class="col-lg-5">
              <div class="search-bar">
                <input type="text" id="vehicle_search_input" class="form-control" placeholder="Buscar por marca, modelo, patente o tipo"/>
              </div>
            </div>
          </div>
        </section>
        <div class="row">
          <div class="col-lg-3 mb-4">
            <aside class="filter-panel">
              <h4>Filtros</h4>
              <div class="filter-group">
                <label for="filter_brand">Marca</label>
                <select id="filter_brand" class="form-control">
                  <option value="">Todas</option>
                </select>
              </div>
              <div class="filter-group">
                <label for="filter_year">Año</label>
                <select id="filter_year" class="form-control">
                  <option value="">Todos</option>
                </select>
              </div>
              <div class="filter-group">
                <label for="filter_type">Tipo</label>
                <select id="filter_type" class="form-control">
                  <option value="">Todos</option>
                </select>
              </div>
              <div class="filter-summary text-muted small" id="filter_summary">Cargando inventario...</div>
            </aside>
          </div>
          <div class="col-lg-9 vehicle-list-container">
            <div id="home_vehicle_list" class="row"></div>
          </div>
        </div>
        <div class="additional-content oe_structure" data-oe-drop="true">
          <p class="text-muted text-center">Arrastra aquí nuevos bloques para testimonios, financiamiento o banners comerciales.</p>
        </div>
      </div>
    </t>
  </template>
</odoo>
