<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <template id="cars_dealersheep_vehicle_gallery_snippet" name="Vehicle Gallery Snippet">
    <t t-name="cars_dealersheep.vehicle_gallery_snippet">
      <section class="s_vehicle_gallery ui-draggable"
               data-oe-type="snippet"
               data-oe-thumbnail="/cars_dealersheep/static/src/img/snippet_thumbnail.png"
               data-oe-drop="true"
               data-snippet-id="vehicle_gallery_snippet">
        <div class="container">
          <div class="vehicle-snippet-heading text-center">
            <span class="vehicle-snippet-kicker">Galería</span>
            <h2 class="o_default_snippet_text">Explora las fotos del vehículo</h2>
            <p class="text-muted">Usa <code>data-vehicle-id</code> para fijar una unidad o deja el snippet en modo automático.</p>
          </div>
          <div class="row vehicle-gallery" data-vehicle-id="">
            <div class="col-12">
              <div class="vehicle-empty-state">
                <p>Cargando imágenes del vehículo...</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </t>
  </template>
</odoo>
