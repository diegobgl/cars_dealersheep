<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="cars_dealersheep_vehicle_snippet" name="Vehicle Snippet">
        <t t-name="cars_dealersheep.vehicle_snippet">
            <section class="s_vehicle_snippet ui-draggable"
                     data-oe-type="snippet"
                     data-oe-thumbnail="/cars_dealersheep/static/src/img/snippet_thumbnail.png"
                     data-oe-drop="true"
                     data-snippet-id="vehicle_snippet">
                <div class="container oe_structure">
                    <div class="vehicle-snippet-heading text-center">
                        <span class="vehicle-snippet-kicker">Inventario</span>
                        <h2 class="o_default_snippet_text">Catálogo de Vehículos</h2>
                        <p class="text-muted">Muestra las unidades publicadas con acceso directo a su ficha.</p>
                    </div>
                    <div class="vehicle-list row"></div>
                </div>
            </section>
        </t>
    </template>
</odoo>
